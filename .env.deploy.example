# Copy to .env.deploy before running `docker compose up -d --build`.

PROJECT_NAME=Deeting Core
ENVIRONMENT=production
DEBUG=false
API_V1_STR=/api/v1

POSTGRES_USER=deeting
POSTGRES_PASSWORD=change_me
POSTGRES_DB=deeting_core

DATABASE_URL=postgresql+asyncpg://deeting:change_me@postgres:5432/deeting_core
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

CORS_ALLOW_ORIGINS=http://localhost:3000,tauri://localhost,deeting://auth
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

JWT_SECRET_KEY=change_me_for_hs256_fallback
SECRET_KEY=change_me_for_hmac_encryption
JWT_PRIVATE_KEY_PATH=security/private.pem
JWT_PUBLIC_KEY_PATH=security/public.pem

# Required in production for POST /api/v1/auth/login/code.
TURNSTILE_SECRET_KEY=

# Email verification
AUTH_EMAIL_PROVIDER=log
BREVO_API_KEY=
BREVO_API_BASE_URL=https://api.brevo.com/v3
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Deeting
BREVO_SANDBOX_MODE=false

# Registration policy
REGISTRATION_CONTROL_ENABLED=false

# Desktop OAuth callback base URLs
DESKTOP_OAUTH_CALLBACK_SCHEME=deeting
DESKTOP_OAUTH_SESSION_TTL_SECONDS=600
DESKTOP_OAUTH_GRANT_TTL_SECONDS=120

GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

GITHUB_OAUTH_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# Keep optional cloud-only systems disabled for this slim auth deployment.
QDRANT_ENABLED=false
MEILISEARCH_URL=
MEILISEARCH_API_KEY=
SCOUT_SERVICE_URL=
ENABLE_SECURITY_MIDDLEWARE=false
