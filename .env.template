# Backend production/staging template
# Copy to: backend/.env
# Keep real secrets out of git.

ENVIRONMENT=production
DEBUG=false

# Core runtime
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/deeting
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# API / CORS
API_V1_STR=/api/v1
CORS_ALLOW_ORIGINS=https://app.deeting.ai
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# Registration / login
REGISTRATION_CONTROL_ENABLED=false
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW=600
VERIFICATION_CODE_TTL_SECONDS=600

# JWT / auth material
# Point these to your real signing keys / secrets according to current backend auth setup.
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=backend/security/private.pem
JWT_PUBLIC_KEY_PATH=backend/security/public.pem

# Desktop OAuth
DESKTOP_OAUTH_CALLBACK_SCHEME=deeting
DESKTOP_OAUTH_SESSION_TTL_SECONDS=600
DESKTOP_OAUTH_GRANT_TTL_SECONDS=120

# Google OAuth
GOOGLE_OAUTH_ENABLED=true
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://api.deeting.ai/api/v1/auth/oauth/google/callback

# GitHub OAuth
GITHUB_OAUTH_ENABLED=true
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=https://api.deeting.ai/api/v1/auth/oauth/github/callback
